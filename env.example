# ═══════════════════════════════════════════════════════════════════════════════
# VM Lifecycle API — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# HOW TO USE
#   cp .env.example .env
#   Edit .env with your values.
#   .env is gitignored — NEVER commit credentials.
#
# SECTIONS
#   1. Application
#   2. Backend (which repository implementation to use)
#   3. Logging (stdout + optional file)
#   4. Mock repository
#   5. SQLite repository
#   6. OpenStack (only needed when BACKEND=openstack)
# ═══════════════════════════════════════════════════════════════════════════════


# ── 1. Application ─────────────────────────────────────────────────────────────
APP_NAME=VM Lifecycle API
APP_VERSION=1.0.0

# Enable debug mode (verbose errors, auto-reload).
# NEVER set to true in production.
DEBUG=false


# ── 2. Backend ─────────────────────────────────────────────────────────────────
# Controls which storage backend is used for VM state.
#
#   mock      → In-memory dict. No persistence across restarts.
#               Best for: local dev, CI, demos.
#
#   sqlite    → SQLite file on disk. Survives restarts. No server required.
#               Best for: single-node dev/staging, functional testing.
#
#   openstack → Real OpenStack cloud via openstacksdk.
#               Best for: production, integration testing against real cloud.
#               Requires: OS_* credentials below (or clouds.yaml).
#
BACKEND=mock


# ── 3. Logging ─────────────────────────────────────────────────────────────────
# Level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Format:
#   json → Structured JSON lines (one object per log record).
#           Use in production — log aggregators (Loki, Datadog, CloudWatch)
#           can index fields like vm_id and request_id without regex.
#   text → Human-readable lines. Easier to read during local development.
LOG_FORMAT=json

# File logging (optional).
# When set, logs are written to BOTH stdout AND this file simultaneously.
# Leave commented/empty to log to stdout only (recommended for containers
# where the runtime captures stdout, e.g. Docker, Kubernetes, ECS).
#
# LOG_FILE=./logs/app.log

# Rotation settings (only apply when LOG_FILE is set).
# Default: 10 MB per file, 5 backups → max 50 MB on disk.
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5


# ── 4. Mock repository ──────────────────────────────────────────────────────────
# Only applies when BACKEND=mock.
#
# Seconds to wait before a newly-created VM transitions from BUILD → ACTIVE.
# Set to 0 to make the transition instant (useful in development).
MOCK_BUILD_DELAY_SECONDS=10


# ── 5. SQLite repository ────────────────────────────────────────────────────────
# Only applies when BACKEND=sqlite.
#
# Path to the SQLite database file. Created automatically if it does not exist.
# The parent directory is also created automatically.
SQLITE_DB_PATH=./data/vms.db

# Seconds before BUILD → ACTIVE transition (same semantics as mock).
SQLITE_BUILD_DELAY_SECONDS=10


# ── 6. OpenStack ────────────────────────────────────────────────────────────────
# Only applies when BACKEND=openstack.
#
# RECOMMENDED: use clouds.yaml instead of env vars.
# See clouds.yaml.example — openstacksdk resolves clouds.yaml first.
#
# If you prefer env vars (e.g. CI pipelines where file injection is hard):

OS_CLOUD=devstack

# Keystone v3 identity endpoint.
OS_AUTH_URL=http://your-openstack-host:5000/v3

# Credentials. Use a service account, not a personal user.
OS_USERNAME=admin
OS_PASSWORD=your-password

# Project (tenant) to create VMs in.
OS_PROJECT_NAME=admin

# Domain names (usually "Default" for DevStack / all-in-one setups).
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
